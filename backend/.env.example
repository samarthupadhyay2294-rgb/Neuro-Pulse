# Flask
FLASK_SECRET_KEY=change-me-to-a-long-random-string
JWT_SECRET_KEY=change-me-jwt-secret

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/neuro_pulse?retryWrites=true&w=majority
MONGODB_DB=neuro_pulse

# Google / Firebase (for Google Sign-In token verification)
GOOGLE_CLIENT_ID=your-firebase-web-client-id.apps.googleusercontent.com
FIREBASE_PROJECT_ID=your-firebase-project-id

# Cloudinary (audio storage — optional; falls back to local uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (password reset — optional in dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Neuro Pulse <noreply@neuropulse.app>
FRONTEND_URL=http://localhost:5173
